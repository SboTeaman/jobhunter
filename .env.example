# Skopiuj ten plik do .env i uzupełnij.

# --- AI (opcjonalne - do generowania listów motywacyjnych) ---
# Bez klucza listy generowane są z szablonu; dopasowanie ofert działa zawsze.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# --- Powiadomienia e-mail (opcjonalne - używane przez watch.py) ---
# Gmail: SMTP_HOST=smtp.gmail.com, port=587, hasło = App Password (nie zwykłe).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=
