{
  "manifest_version": 3,
  "name": "JobHunter",
  "version": "1.0",
  "description": "Zapisz ofertę IT jednym kliknięciem i sprawdź dopasowanie do CV.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://127.0.0.1:8001/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icon48.png" }
  },
  "content_scripts": [
    {
      "matches": [
        "*://justjoin.it/*",
        "*://nofluffjobs.com/*",
        "*://pracuj.pl/*",
        "*://theprotocol.it/*",
        "*://remoteok.com/*",
        "*://weworkremotely.com/*",
        "*://*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
